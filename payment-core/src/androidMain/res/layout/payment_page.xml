<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <FrameLayout
            android:id="@+id/frameCard"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="15dp"
            tools:ignore="MissingConstraints">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPreviewFront"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardBackgroundColor="@color/card_blue"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toTopOf="parent">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_card_gradient"
                    android:padding="24dp">
                    <TextView
                        android:id="@+id/tvCardNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:paddingTop="35dp"
                        android:text="XXXX XXXX XXXX 2459"
                        android:textColor="@android:color/white"
                        android:textSize="29sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvCardNumber"
                        android:layout_marginTop="5dp"
                        android:text="Card holder name"
                        android:textColor="@android:color/white"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tvNamePreview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:text="John doe"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvCardNumber"
                        android:layout_marginLeft="150dp"
                        android:layout_marginTop="5dp"
                        android:text="Expiry Date"
                        android:textColor="@android:color/white"
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/tvExpDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_marginLeft="150dp"
                        android:text="******"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:src="@drawable/chip" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPreviewBack"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardBackgroundColor="@color/card_blue"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:app="http://schemas.android.com/apk/res-auto">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="40dp">
                    <!-- Magnetic stripe -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="#000000"/>
                    <!-- CVV area -->
                    <TextView
                        android:id="@+id/tvCvvPreview"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:text="***"
                        android:layout_marginTop="20dp"
                        android:padding="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <TextView
            android:id="@+id/lblCardNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Card Holder Number"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/frameCard"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCardNumber"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:inputType="number"
            android:hint="XXXX XXXX XXXX 2459"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/lblCardNumber" />

        <LinearLayout
            android:id="@+id/layoutLogos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etCardNumber">
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowExpired"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/layoutLogos">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expired Date"
                    android:textStyle="bold"/>
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etExpDate"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="MM/YYYY"
                    android:inputType="datetime"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CVN/CVV"
                    android:textStyle="bold"/>
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCVV"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:inputType="number"
                    android:hint="****"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutCardName"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/rowExpired"
            app:layout_constraintStart_toStartOf="parent" >
            <TextView
                android:id="@+id/lblCardNumber2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Card Holder Name"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/rowExpired"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/etCardName2"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="John doe"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/lblCardNumber2" />
        </LinearLayout>


        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Simpan Informasi Kartu"
            app:layout_constraintTop_toBottomOf="@id/layoutCardName"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/layoutAlert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E3F2FD"
            android:padding="12dp"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/switchSave">

            <CheckBox
                android:id="@+id/checkbox"
                android:layout_width="24dp"
                android:layout_height="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textSize="12sp"
                android:text="Seluruh data kamu dijamin aman. Setiap transaksi kami akan meminta verifikasi kamu." />
        </LinearLayout>

        <Button
            android:id="@+id/btnPay"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_rounded"
            android:backgroundTint="@color/button_dark"
            android:text="Payment"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toBottomOf="@id/layoutAlert"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="20dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
    

</ScrollView>