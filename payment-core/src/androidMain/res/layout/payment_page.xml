<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@android:color/white">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:background="@android:color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:ignore="MissingConstraints">

            <FrameLayout
                android:id="@+id/frameCard"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="15dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPreviewFront"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    app:cardBackgroundColor="@color/card_blue"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:layout_constraintTop_toTopOf="parent">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_card_gradient"
                        android:padding="24dp">
                        <TextView
                            android:id="@+id/tvCardNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:paddingTop="35dp"
                            android:text="XXXX XXXX XXXX 2459"
                            android:textColor="@android:color/white"
                            android:textSize="29sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tvCardNumber"
                            android:layout_marginTop="5dp"
                            android:text="Card holder name"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/tvNamePreview"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:text="John doe"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tvCardNumber"
                            android:layout_marginLeft="150dp"
                            android:layout_marginTop="5dp"
                            android:text="Expiry Date"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tvExpDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:layout_marginLeft="150dp"
                            android:text="******"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:src="@drawable/chip" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPreviewBack"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    app:cardBackgroundColor="@color/card_blue"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    android:visibility="gone"
                    app:layout_constraintTop_toTopOf="parent"
                    xmlns:android="http://schemas.android.com/apk/res/android"
                    xmlns:app="http://schemas.android.com/apk/res-auto">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="40dp">
                        <!-- Magnetic stripe -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="#000000"/>
                        <!-- CVV area -->
                        <TextView
                            android:id="@+id/tvCvvPreview"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:background="#FFFFFF"
                            android:text="***"
                            android:layout_marginTop="20dp"
                            android:padding="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/layoutTap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="15dp"
                app:cardElevation="8dp"
                android:layout_marginTop="20dp"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="8dp"
                app:cardBackgroundColor="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/frameCard"
                tools:ignore="MissingConstraints">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_corners_shadow"
                    android:orientation="horizontal"
                    android:padding="15dp"
                    android:elevation="6dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="67dp"
                        android:layout_height="43dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:src="@drawable/tapcard" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:textSize="12sp"
                        android:text="Just tap the card to your device, and the card information will be filled in automatically." />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/lblCardNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="Card Number"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/layoutTap"
                app:layout_constraintStart_toStartOf="parent" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCardNumber"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:inputType="number"
                android:hint="XXXX XXXX XXXX 2459"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/lblCardNumber" />

            <LinearLayout
                android:id="@+id/layoutLogos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/etCardNumber">

                <ImageView
                    android:id="@+id/ivmastercard"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:alpha="0.21"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:src="@drawable/payment_logo" />
                <ImageView
                    android:id="@+id/ivvisa"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:alpha="0.21"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:src="@drawable/visa" />
                <ImageView
                android:id="@+id/ivjcb"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                    android:alpha="0.21"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:src="@drawable/jcb" />
                <ImageView
                android:id="@+id/ivamex"
                android:layout_width="30dp"
                android:layout_height="30dp"
                    android:alpha="0.21"
                android:layout_gravity="center"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:src="@drawable/amex" />
                <ImageView
                android:id="@+id/ivunion"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                    android:alpha="0.21"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:src="@drawable/unionpay" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowExpired"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/layoutLogos">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expired Date"
                        android:textStyle="bold"/>
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etExpDate"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="MM/YYYY"
                        android:inputType="datetime"
                        android:background="@drawable/bg_input_field"
                        android:paddingHorizontal="16dp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CVN/CVV"
                        android:textStyle="bold"/>
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCVV"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:inputType="number"
                        android:hint="****"
                        android:background="@drawable/bg_input_field"
                        android:paddingHorizontal="16dp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutCardName"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/rowExpired"
                app:layout_constraintStart_toStartOf="parent" >
                <TextView
                    android:id="@+id/lblCardNumber2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Card Holder Name"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/rowExpired"
                    app:layout_constraintStart_toStartOf="parent" />

                <EditText
                    android:id="@+id/etCardName2"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="John doe"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/lblCardNumber2" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytSwitch"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                app:layout_constraintTop_toBottomOf="@id/layoutCardName">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchSave"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textSize="12sp"
                    android:text="Save Card Information"
                    android:layout_marginBottom="4dp"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutAlert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_corners_round"
                android:padding="10dp"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                app:layout_constraintTop_toBottomOf="@id/lytSwitch">

                <CheckBox
                    android:id="@+id/checkbox"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginRight="10dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:text="Your card details are securely protected."
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:textSize="12sp"
                        android:text="We collaborate with banks to ensure the security of your card data. We will not access or misuse your card information." />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnPay"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_button_rounded"
                android:backgroundTint="@color/button_dark"
                android:text="Payment"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:layout_constraintTop_toBottomOf="@id/layoutAlert"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="20dp"/>


        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
    <LinearLayout
        android:id="@+id/bottomSheetScan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/cardview_light_background"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp"
        android:elevation="16dp"
        app:behavior_hideable="true"
        app:behavior_peekHeight="0dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_marginBottom="24dp"
            android:background="#E0E0E0" />

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/tapcard" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Scan your card"
            android:textColor="#212121"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Place your debit/credit card on the back of your phone and hold it for at least 3 seconds. Make sure your card and device support NFC features."
            android:textColor="#9E9E9E"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:background="@color/cardview_light_background"
            android:gravity="center_vertical"
            android:padding="12dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@color/card_blue"
                app:tint="#2979FF" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:layout_marginBottom="10dp"
                android:text="Your Data is Protected"
                android:textColor="#424242"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>